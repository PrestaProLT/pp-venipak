{# Load the admin design system directly here so we do not depend on the
   displayBackOfficeHeader hook firing on Symfony-routed module pages. #}
<link rel="stylesheet" href="/modules/ppvenipak/views/css/prestapro-carrier.css?v=1">
<link rel="stylesheet" href="/modules/ppvenipak/views/css/admin/ppvenipak-admin.css?v=1">
<script src="/modules/ppvenipak/views/js/admin/ppvenipak-admin.js?v=1" defer></script>

<div class="ppv-shell">
    <nav class="ppv-tabs" role="tablist" aria-label="{{ 'PPVenipak admin sections'|trans({}, 'Modules.Ppvenipak.Admin') }}">
        {% for tab in tabs %}
            <a class="ppv-tabs__item{% if active_tab == tab.id %} ppv-tabs__item--active{% endif %}"
               href="{{ path(tab.route) }}"
               role="tab"
               aria-current="{{ active_tab == tab.id ? 'page' : 'false' }}">
                <svg class="ppv-tabs__icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">{{ tab.icon|raw }}</svg>
                <span>{{ tab.label }}</span>
            </a>
        {% endfor %}
    </nav>

    {% if multistore_blocked|default(false) %}
        <div class="ppv-multistore-warning" role="alert">
            {% if multistore_reason|default('group') == 'shared' %}
                <h4>{{ 'Switch to "All shops" to continue'|trans({}, 'Modules.Ppvenipak.Admin') }}</h4>
                <p>{{ 'Per-store authentication is disabled, so credentials are stored once and shared by every shop. Pick "All shops" in the multistore selector at the top of this page to edit them.'|trans({}, 'Modules.Ppvenipak.Admin') }}</p>
            {% else %}
                <h4>{{ 'Pick a specific shop to continue'|trans({}, 'Modules.Ppvenipak.Admin') }}</h4>
                <p>{{ 'Per-store authentication is enabled. Editing module data in "All shops" or a shop group context could overwrite per-shop credentials and warehouse data.'|trans({}, 'Modules.Ppvenipak.Admin') }}</p>
                <p><strong>{{ 'Use the multistore selector at the top of this page to choose one shop, then return to this section.'|trans({}, 'Modules.Ppvenipak.Admin') }}</strong></p>
            {% endif %}
        </div>
    {% endif %}

    <header class="ppv-page-header">
        <div>
            <h1 class="ppv-page-header__title">{{ page_title }}</h1>
            {% if page_description|default('') %}
                <p class="ppv-page-header__description">{{ page_description }}</p>
            {% endif %}
        </div>
        {% if page_actions|default('') %}
            <div class="ppv-page-header__actions">{{ page_actions|raw }}</div>
        {% endif %}
    </header>
</div>
